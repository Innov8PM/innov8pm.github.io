---
const sectors = [
  {
    name: 'Energy — Residential and Commercial',
    description: 'Live debt visits, including Welfare & vulnerability visits. Commercial debt visits, Occupancy verification. Meter related visits. Warrant Services (pre payment, disconnection, faulty meter).',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  },
  {
    name: 'Water — Household and Non Household',
    description: 'Live Debt Household Engagement visits. Retailer Live Debt visits / Temporary Disconnections. Non Household Warrant services (internal access — non payment, long term unread meters, Investigation, meter installation). Occupancy verification.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3c-4 6-7 9-7 12.5a7 7 0 1014 0C19 12 16 9 12 3z" />`,
  },
  {
    name: 'Financial Services',
    description: 'Mortgage Arrears. Reconnection Visits. Income and Expenditure / Pre Litigation.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
  },
  {
    name: 'DCA / Debt Purchase',
    description: 'Reconnection Visits. Pre Litigation. Affordability Assessments.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
]
---

<section id="sectors" class="py-24 md:py-32 bg-gray-50/30 relative overflow-hidden">
  <div class="absolute inset-0 chevron-grid opacity-30 -z-10"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-20">
      <p class="reveal text-xs font-semibold text-brand-600 uppercase tracking-[0.2em] mb-4 font-display">Sectors</p>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-[2.75rem] font-bold tracking-[-0.02em] text-charcoal leading-tight font-display">
        Built for ALL industries
      </h2>
      <p class="reveal reveal-delay-2 mt-5 text-lg text-charcoal-light leading-relaxed">
        If you're sending a field operative to a location to undertake a task, compliance standards matter. We believe in best practice and innovation.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {sectors.map((sector, i) => (
        <div class={`reveal reveal-delay-${(i % 2) + 1} group p-8 bg-white rounded-2xl border border-gray-100 hover:border-brand-200/60 transition-all duration-500 hover:shadow-xl hover:shadow-brand-50`}>
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center shrink-0 group-hover:from-brand-100 group-hover:to-brand-200 transition-all duration-500">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={sector.icon} />
              </svg>
            </div>
            <div>
              <div class="flex items-center gap-3 mb-3">
                <h3 class="text-lg font-bold text-charcoal font-display">{sector.name}</h3>
              </div>
              <p class="text-[15px] text-charcoal-light leading-relaxed">{sector.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
