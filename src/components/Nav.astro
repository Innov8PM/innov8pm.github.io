---
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logo.png" alt="Innov-8" class="h-8" />
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#how-it-works" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">How It Works</a>
      <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Features</a>
      <a href="#sectors" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Sectors</a>
      <a href="#contact" class="inline-flex items-center justify-center h-9 px-5 text-sm font-semibold text-white bg-brand-500 rounded-lg hover:bg-brand-600 transition-colors">Get in Touch</a>
    </div>
    <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-gray-900" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href="#how-it-works" class="text-sm font-medium text-gray-600 hover:text-gray-900">How It Works</a>
      <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900">Features</a>
      <a href="#sectors" class="text-sm font-medium text-gray-600 hover:text-gray-900">Sectors</a>
      <a href="#contact" class="inline-flex items-center justify-center h-10 px-5 text-sm font-semibold text-white bg-brand-500 rounded-lg hover:bg-brand-600">Get in Touch</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'))
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')))
</script>
