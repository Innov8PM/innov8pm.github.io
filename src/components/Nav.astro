---
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100/80">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 h-24 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logo.png" alt="Innov-8" class="h-20" />
    </a>
    <div class="hidden md:flex items-center gap-10">
      <a href="#how-it-works" class="text-[13px] font-medium tracking-wide uppercase text-charcoal-light hover:text-brand-600 transition-colors duration-300">How It Works</a>
      <a href="#features" class="text-[13px] font-medium tracking-wide uppercase text-charcoal-light hover:text-brand-600 transition-colors duration-300">Features</a>
      <a href="#sectors" class="text-[13px] font-medium tracking-wide uppercase text-charcoal-light hover:text-brand-600 transition-colors duration-300">Sectors</a>
      <a href="#contact" class="inline-flex items-center justify-center h-10 px-6 text-[13px] font-semibold tracking-wide uppercase text-white bg-brand-500 rounded-full hover:bg-brand-600 transition-all duration-300 hover:shadow-lg hover:shadow-brand-500/25 hover:-translate-y-px">
        Get in Touch
      </a>
    </div>
    <button id="mobile-menu-btn" class="md:hidden p-2 text-charcoal hover:text-brand-600 transition-colors" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white/95 backdrop-blur-xl">
    <div class="px-6 py-6 flex flex-col gap-5">
      <a href="#how-it-works" class="text-sm font-medium text-charcoal-light hover:text-brand-600">How It Works</a>
      <a href="#features" class="text-sm font-medium text-charcoal-light hover:text-brand-600">Features</a>
      <a href="#sectors" class="text-sm font-medium text-charcoal-light hover:text-brand-600">Sectors</a>
      <a href="#contact" class="inline-flex items-center justify-center h-11 px-6 text-sm font-semibold text-white bg-brand-500 rounded-full hover:bg-brand-600">Get in Touch</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'))
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')))
</script>
