---
const audiences = [
  {
    title: 'For Utility Companies',
    subtitle: 'Commissioners of field services',
    items: [
      'Full operational visibility across all agencies and services',
      'Performance dashboards with drill-down by region and agency',
      'Eliminate procurement overhead for new agencies',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
  },
  {
    title: 'For Field Agencies',
    subtitle: 'Providers of field services',
    items: [
      'Access new customers without costly procurement processes',
      'Compete on a level playing field based on performance, not size',
      'Transparent invoicing with full backing data',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`,
  },
  {
    title: 'For Innov-8 Operations',
    subtitle: 'Panel management team',
    items: [
      'Cross-customer, cross-agency operational overview',
      'Proactive alerts for capacity gaps and issues',
      'Full configuration of customers, agencies, and cycles',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
]
---

<section class="py-24 md:py-32 relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-20">
      <p class="reveal text-xs font-semibold text-brand-600 uppercase tracking-[0.2em] mb-4 font-display">Who It's For</p>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-[2.75rem] font-bold tracking-[-0.02em] text-charcoal leading-tight font-display">
        Built for every stakeholder
      </h2>
      <p class="reveal reveal-delay-2 mt-5 text-lg text-charcoal-light leading-relaxed">
        Whether you commission field services, deliver them, or manage the panel — Innov-8 gives you exactly the visibility you need.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      {audiences.map((aud, i) => (
        <div class={`reveal reveal-delay-${i + 1} group rounded-2xl border border-gray-100 overflow-hidden bg-white hover:border-brand-200/60 transition-all duration-500 hover:shadow-xl hover:shadow-brand-50`}>
          <div class="p-8 pb-0">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center group-hover:from-brand-100 group-hover:to-brand-200 transition-all duration-500">
                <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={aud.icon} />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-charcoal font-display">{aud.title}</h3>
                <p class="text-xs text-charcoal-light font-medium mt-0.5">{aud.subtitle}</p>
              </div>
            </div>
          </div>

          <div class="px-8 pb-8">
            <ul class="space-y-3">
              {aud.items.map(item => (
                <li class="flex gap-3 text-[15px] text-charcoal-light leading-relaxed">
                  <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Decorative bottom gradient -->
          <div class="h-1 bg-gradient-to-r from-brand-300 via-brand-500 to-brand-300 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>
