---
---

<section class="py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-charcoal">
        Built for every stakeholder
      </h2>
      <p class="mt-4 text-lg text-gray-600 leading-relaxed">
        Whether you commission field services, deliver them, or manage the panel — innov8 gives you exactly the visibility you need.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Customer -->
      <div class="rounded-2xl border border-gray-100 overflow-hidden">
        <div class="p-1.5">
          <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center">
            <div class="text-center text-brand-300">
              <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              <p class="text-xs font-medium">Screenshot Placeholder</p>
            </div>
          </div>
        </div>
        <div class="p-6 pt-4">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">For Utility Companies</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Full operational visibility across all agencies and services
            </li>
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Performance dashboards with drill-down by region and agency
            </li>
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Eliminate procurement overhead for new agencies
            </li>
          </ul>
        </div>
      </div>

      <!-- Agency -->
      <div class="rounded-2xl border border-gray-100 overflow-hidden">
        <div class="p-1.5">
          <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center">
            <div class="text-center text-brand-300">
              <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <p class="text-xs font-medium">Screenshot Placeholder</p>
            </div>
          </div>
        </div>
        <div class="p-6 pt-4">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">For Field Agencies</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Access new customers without costly procurement processes
            </li>
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Compete on a level playing field based on performance, not size
            </li>
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Transparent invoicing with full backing data
            </li>
          </ul>
        </div>
      </div>

      <!-- Innov8 Ops -->
      <div class="rounded-2xl border border-gray-100 overflow-hidden">
        <div class="p-1.5">
          <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center">
            <div class="text-center text-brand-300">
              <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <p class="text-xs font-medium">Screenshot Placeholder</p>
            </div>
          </div>
        </div>
        <div class="p-6 pt-4">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">For Innov-8 Operations</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Cross-customer, cross-agency operational overview
            </li>
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Proactive alerts for capacity gaps and issues
            </li>
            <li class="flex gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Full configuration of customers, agencies, and cycles
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
