---

<section id="features" class="py-24 md:py-32 bg-gray-50/50 relative overflow-hidden">
  <div class="absolute inset-0 chevron-grid -z-10 opacity-50"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center mb-20">
      <p class="reveal text-xs font-semibold text-brand-600 uppercase tracking-[0.2em] mb-4 font-display">Features</p>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-[2.75rem] font-bold tracking-[-0.02em] text-charcoal leading-tight font-display">
        Everything you need to manage your panel
      </h2>
      <p class="reveal reveal-delay-2 mt-5 text-lg text-charcoal-light leading-relaxed">
        Replace spreadsheets, emails, and manual processes with a single platform that gives every stakeholder the visibility they need.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} group relative p-8 rounded-2xl bg-white border border-gray-100 hover:border-brand-200/60 transition-all duration-500 hover:shadow-xl hover:shadow-brand-50`}>
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center mb-6 group-hover:from-brand-100 group-hover:to-brand-200 transition-all duration-500">
            <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={feature.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal mb-3 font-display">{feature.title}</h3>
          <p class="text-[15px] text-charcoal-light leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
