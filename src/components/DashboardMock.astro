---
---

<section class="py-4 md:py-8 -mt-8 relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="reveal relative">
      <div class="absolute -inset-4 bg-gradient-to-r from-brand-200/20 via-brand-300/10 to-brand-200/20 rounded-3xl blur-2xl"></div>

      <div class="relative rounded-2xl border border-gray-200/80 bg-white shadow-2xl shadow-gray-900/8 overflow-hidden">
        <!-- Top bar -->
        <div class="flex items-center justify-between px-5 py-3 bg-brand-950 text-white">
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 rounded bg-brand-500 flex items-center justify-center">
              <span class="text-[9px] font-extrabold">i8</span>
            </div>
            <span class="text-xs font-semibold font-display tracking-wide">Innov-8 Platform</span>
          </div>
          <div class="flex items-center gap-4 text-[10px] text-brand-300/70">
            <span>Cycle 3 &middot; Week 8 of 12</span>
            <div class="w-6 h-6 rounded-full bg-brand-800 flex items-center justify-center text-[9px] font-bold text-white">JM</div>
          </div>
        </div>

        <div class="flex">
          <!-- Sidebar -->
          <div class="hidden md:flex flex-col w-44 shrink-0 bg-gray-50 border-r border-gray-100 py-4 px-3 gap-0.5">
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg bg-brand-50 text-brand-700">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
              <span class="text-[11px] font-semibold">Dashboard</span>
            </div>
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg text-gray-400 hover:text-gray-600">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
              <span class="text-[11px] font-medium">Services</span>
            </div>
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg text-gray-400 hover:text-gray-600">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span class="text-[11px] font-medium">Agencies</span>
            </div>
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg text-gray-400 hover:text-gray-600">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              <span class="text-[11px] font-medium">Performance</span>
            </div>
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg text-gray-400 hover:text-gray-600">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
              <span class="text-[11px] font-medium">Complaints</span>
            </div>
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg text-gray-400 hover:text-gray-600">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span class="text-[11px] font-medium">Exception Mgmt</span>
            </div>
            <div class="flex items-center gap-2 px-2.5 py-2 rounded-lg text-gray-400 hover:text-gray-600">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
              <span class="text-[11px] font-medium">Billing</span>
            </div>
          </div>

          <!-- Main content -->
          <div class="flex-1 p-4 md:p-5 bg-gray-50/50 min-h-[340px] md:min-h-[420px]">
            <!-- Header row -->
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="text-sm font-bold text-charcoal font-display">Energy Supplier A &mdash; Overview</h3>
                <p class="text-[10px] text-charcoal-light mt-0.5">Residential Energy &middot; 4 services &middot; 6 agencies</p>
              </div>
              <div class="flex gap-2">
                <div class="px-2.5 py-1 rounded-md bg-white border border-gray-200 text-[10px] text-charcoal-light font-medium">This Cycle</div>
                <div class="px-2.5 py-1 rounded-md bg-white border border-gray-200 text-[10px] text-charcoal-light font-medium hidden sm:block">Export</div>
              </div>
            </div>

            <!-- KPI row -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
              <div class="bg-white rounded-xl border border-gray-100 p-3">
                <p class="text-[10px] text-charcoal-light font-medium mb-1">Live Cases</p>
                <p class="text-xl font-bold text-charcoal font-display">2,847</p>
                <div class="flex items-center gap-1 mt-1">
                  <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  <span class="text-[10px] font-semibold text-emerald-600">+12.3%</span>
                </div>
              </div>
              <div class="bg-white rounded-xl border border-gray-100 p-3">
                <p class="text-[10px] text-charcoal-light font-medium mb-1">In SLA</p>
                <p class="text-xl font-bold text-charcoal font-display">99.2%</p>
                <div class="flex items-center gap-1 mt-1">
                  <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  <span class="text-[10px] font-semibold text-emerald-600">+2.1pp</span>
                </div>
              </div>
              <div class="bg-white rounded-xl border border-gray-100 p-3">
                <p class="text-[10px] text-charcoal-light font-medium mb-1">Positive Outcome</p>
                <p class="text-xl font-bold text-charcoal font-display">68.4%</p>
                <div class="flex items-center gap-1 mt-1">
                  <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  <span class="text-[10px] font-semibold text-emerald-600">+5.8pp</span>
                </div>
              </div>
              <div class="bg-white rounded-xl border border-gray-100 p-3">
                <p class="text-[10px] text-charcoal-light font-medium mb-1">Agencies</p>
                <p class="text-xl font-bold text-charcoal font-display">6</p>
                <div class="flex items-center gap-1 mt-1">
                  <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  <span class="text-[10px] font-semibold text-emerald-600">+2</span>
                </div>
              </div>
            </div>

            <!-- Two column layout -->
            <div class="grid md:grid-cols-5 gap-3">
              <!-- Performance by service (chart area) -->
              <div class="md:col-span-3 bg-white rounded-xl border border-gray-100 p-4">
                <div class="flex items-center justify-between mb-4">
                  <p class="text-[11px] font-bold text-charcoal font-display">Performance by Service</p>
                  <p class="text-[10px] text-charcoal-light">Driver: Positive Outcome Rate</p>
                </div>
                <!-- Simplified bar chart -->
                <div class="space-y-3">
                  <div>
                    <div class="flex justify-between mb-1">
                      <span class="text-[10px] font-medium text-charcoal">Meter Reading</span>
                      <span class="text-[10px] font-semibold text-charcoal">74.2%</span>
                    </div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-500 rounded-full" style="width: 74.2%"></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between mb-1">
                      <span class="text-[10px] font-medium text-charcoal">Installation</span>
                      <span class="text-[10px] font-semibold text-charcoal">68.9%</span>
                    </div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-400 rounded-full" style="width: 68.9%"></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between mb-1">
                      <span class="text-[10px] font-medium text-charcoal">Disconnection</span>
                      <span class="text-[10px] font-semibold text-charcoal">61.3%</span>
                    </div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-300 rounded-full" style="width: 61.3%"></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between mb-1">
                      <span class="text-[10px] font-medium text-charcoal">Reconnection</span>
                      <span class="text-[10px] font-semibold text-charcoal">58.7%</span>
                    </div>
                    <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full bg-brand-200 rounded-full" style="width: 58.7%"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Agency ranking -->
              <div class="md:col-span-2 bg-white rounded-xl border border-gray-100 p-4">
                <p class="text-[11px] font-bold text-charcoal font-display mb-4">Top 3 Agency Ranking</p>
                <div class="space-y-3">
                  <div class="flex items-center gap-3">
                    <div class="w-5 h-5 rounded-full bg-amber-100 flex items-center justify-center shrink-0">
                      <span class="text-[9px] font-bold text-amber-700">1</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-[11px] font-semibold text-charcoal truncate">Field Agency B</p>
                      <p class="text-[10px] text-charcoal-light">76.1% &middot; 1,142 cases</p>
                    </div>
                    <svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="w-5 h-5 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
                      <span class="text-[9px] font-bold text-gray-600">2</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-[11px] font-semibold text-charcoal truncate">Field Agency D</p>
                      <p class="text-[10px] text-charcoal-light">71.4% &middot; 986 cases</p>
                    </div>
                    <svg class="w-3.5 h-3.5 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="w-5 h-5 rounded-full bg-orange-100 flex items-center justify-center shrink-0">
                      <span class="text-[9px] font-bold text-orange-700">3</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-[11px] font-semibold text-charcoal truncate">Field Agency E</p>
                      <p class="text-[10px] text-charcoal-light">64.8% &middot; 719 cases</p>
                    </div>
                    <svg class="w-3.5 h-3.5 text-red-400 shrink-0 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                  </div>
                </div>

                <!-- Regional mini-map placeholder -->
                <div class="mt-4 pt-3 border-t border-gray-100">
                  <p class="text-[11px] font-bold text-charcoal font-display mb-3">Cases by Region</p>
                  <div class="grid grid-cols-4 gap-1.5">
                    <div class="text-center">
                      <div class="h-8 rounded bg-brand-100 flex items-end justify-center pb-0.5">
                        <div class="w-full mx-0.5 rounded-t bg-brand-500" style="height: 70%"></div>
                      </div>
                      <p class="text-[8px] text-charcoal-light mt-1">North West</p>
                    </div>
                    <div class="text-center">
                      <div class="h-8 rounded bg-brand-100 flex items-end justify-center pb-0.5">
                        <div class="w-full mx-0.5 rounded-t bg-brand-500" style="height: 55%"></div>
                      </div>
                      <p class="text-[8px] text-charcoal-light mt-1">East Midlands</p>
                    </div>
                    <div class="text-center">
                      <div class="h-8 rounded bg-brand-100 flex items-end justify-center pb-0.5">
                        <div class="w-full mx-0.5 rounded-t bg-brand-500" style="height: 40%"></div>
                      </div>
                      <p class="text-[8px] text-charcoal-light mt-1">South Wales</p>
                    </div>
                    <div class="text-center">
                      <div class="h-8 rounded bg-brand-100 flex items-end justify-center pb-0.5">
                        <div class="w-full mx-0.5 rounded-t bg-brand-400" style="height: 30%"></div>
                      </div>
                      <p class="text-[8px] text-charcoal-light mt-1">Scotland</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
