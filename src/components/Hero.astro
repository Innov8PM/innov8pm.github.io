---

<section class="relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-brand-50/30 -z-10"></div>
  <div class="absolute top-20 right-0 w-[600px] h-[600px] bg-brand-100/40 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-brand-50/60 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 border border-brand-200 text-brand-700 text-sm font-medium mb-6">
        <span class="w-2 h-2 bg-brand-500 rounded-full"></span>
        Panel Management Platform
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-charcoal leading-[1.1]">
        One platform to manage your
        <span class="text-brand-500">field service agencies</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-charcoal-light leading-relaxed max-w-2xl">
        Innov-8 replaces fragmented agency relationships with a single, data-driven platform. Allocate cases, track performance, and drive transparency across your entire field services panel.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="#contact" class="inline-flex items-center justify-center h-12 px-8 text-base font-semibold text-white bg-brand-500 rounded-lg hover:bg-brand-600 transition-colors shadow-lg shadow-brand-500/20">
          Request a Demo
        </a>
        <a href="#how-it-works" class="inline-flex items-center justify-center h-12 px-8 text-base font-semibold text-gray-700 bg-white rounded-lg border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-colors">
          Learn More
        </a>
      </div>
    </div>

    <!-- Hero visual placeholder -->
    <div class="mt-16 rounded-2xl border border-gray-200 bg-white shadow-2xl shadow-gray-200/50 overflow-hidden">
      <div class="aspect-[16/8] bg-gradient-to-br from-brand-50 to-brand-100 flex items-center justify-center">
        <div class="text-center text-brand-300">
          <svg class="w-16 h-16 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
          </svg>
          <p class="text-sm font-medium">Platform Dashboard Screenshot</p>
        </div>
      </div>
    </div>
  </div>
</section>
